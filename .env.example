# Trading Journal / GEX Terminal environment keys (no secret values)
# Source of truth for required deployment variables.

# Market data
POLYGON_API_KEY=

# Alerting
DISCORD_WEBHOOK_URL=
DISCORD_OPTIONS_WEBHOOK_URL=

# Optional broker runtime config (read-only mode defaults)
IBKR_ACCOUNT_ID=
