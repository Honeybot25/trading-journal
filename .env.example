# Discord Webhook Configuration for Options Alerts
# Copy this file to .env and fill in your webhook URL

# Required: Discord webhook URL for #trading-alerts channel
# Get this from: Discord Server Settings → Integrations → Webhooks
DISCORD_OPTIONS_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: Channel name (for logging)
DISCORD_CHANNEL_NAME=trading-alerts

# Optional: Minimum confidence threshold (default: 75)
CONFIDENCE_THRESHOLD=75

# Optional: Duplicate cooldown in milliseconds (default: 3600000 = 1 hour)
DUPLICATE_COOLDOWN_MS=3600000

# Optional: Mission Control dashboard URL
MISSION_CONTROL_URL=https://mission-control-lovat-rho.vercel.app

# Optional: Set to 'true' to prefix all alerts with TEST
TEST_MODE=false
